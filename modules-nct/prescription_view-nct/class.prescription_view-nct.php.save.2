    				background: #f8f8f8;
    				text-align: center;
			}
		';

		$mpdf->WriteHTML('<style>'.$pdfCSS.'</style>',1);
		$mpdf->WriteHTML($html,2);

    		$mpdf->Output('prescription.pdf', 'I');
    		exit;
	}

	return $tpl;
    }
