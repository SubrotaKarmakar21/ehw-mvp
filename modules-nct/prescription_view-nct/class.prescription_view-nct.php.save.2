        		<div class="text-center print-button-wrapper">
            			<a href="?prescription_id='.$prescription_id.'&action=print" class="btn btn-ehw-green print-btn">Print Prescription</a>
        		</div>
    		';
	}

        $replace = array(
	    "%PRESCRIPTION_ID%"		=> $prescription_id,
            "%DOCTOR_NAME%" 		=> $doctorName,
	    "%DOCTOR_CATEGORY%"		=> $doctorCategoryHtml,
	    "%DOCTOR_DESCRIPTION%"	=> $doctorDescriptionHtml,
	    "%CLINIC_BANNER%"		=> $clinicBanner,
	    "%CLINIC_INFO%"		=> $clinicInfoHtml,
	    "%PATIENT_NAME%" 		=> $patientName,
	    "%PATIENT_AGE%" 		=> $ageDisplay,
	    "%PATIENT_GENDER%" 		=> $gender,
	    "%PRESCRIPTION_DATE%" 	=> $date,
	    "%VITALS%"			=> $vitalsHtml,
	    "%COMPLAINTS%"		=> $complaintsHtml,
	    "%DIAGNOSIS%"		=> $diagnosisHtml,
	    "%MEDICATIONS%"		=> $medicationsHtml,
	    "%INVESTIGATIONS%"		=> $investigationHtml,
	    "%FOLLOWUP%"		=> $followupHtml,
	    "%GENERAL_ADVICE%"		=> $generalAdviceHtml,
	    "%DIET_PLAN%"		=> $dietHtml,
	    "%DOS_DONTS%"		=> $dosDontsHtml,
	    "%DOCTOR_SIGNATURE%"	=> $signatureHtml,
	    "%PRINT_BUTTON_HTML%"	=> $printButtonHtml
        );

	$tpl = $this->renderTemplate($template, $replace);

	/* PRINT MODE */
	if($printMode){

    		if (ob_get_length()) ob_clean();

    		require_once $_SERVER['DOCUMENT_ROOT'].'/vendor/autoload.php';

		// PDF SAFE HTML

		$complaintsHtmlPdf = '';

		if(!empty($prescription['complaints_json'])){
    			$complaints = json_decode($prescription['complaints_json'], true);

    			if(!empty($complaints)){
        			$complaintsHtmlPdf .= '<table width="100%" style="font-size:15px;">';

        			$first = true;

        			foreach($complaints as $c){
