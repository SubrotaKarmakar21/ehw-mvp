<?php
class MyServices {

    public function __construct($module = "", $reqData = array())
{
    foreach ($GLOBALS as $key => $values) {
        $this->$key = $values;
    }

    $this->module   = $module;
    $this->reqData  = $reqData;
    $this->userData = getUserData();

    $this->dataOnly = (isset($this->reqData['dataOnly']) && $this->reqData['dataOnly']==true)?true:false;
    $this->sessUserId = (isset($reqData['userId']) && $reqData['userId'] >0)?$reqData['userId']:$this->sessUserId;
}

    /* ================================
       LIST SERVICES
    ================================= */
    public function getServicesList() {

        $clinic_id = $this->sessUserId;

        $services = $this->db->pdoQuery("
            SELECT s.*, c.category_name
            FROM tbl_clinic_services s
            JOIN tbl_service_categories c ON c.id = s.category_id
            WHERE s.clinic_id = ? AND s.status = 'a'
            ORDER BY s.created_date DESC
        ", [$clinic_id])->results();

        return $services;
    }

    /* ================================
       ADD SERVICE
    ================================= */
    public function addService() {

        $clinic_id = $this->sessUserId;

        $insert = [
            "clinic_id"   => $clinic_id,
            "category_id" => $_POST['category_id'],
            "service_name"=> $_POST['service_name'],
            "price"       => $_POST['price'],
            "description" => $_POST['description'],
            "status"      => 'a',
            "created_date"=> date("Y-m-d H:i:s")
        ];

        $this->db->insert("tbl_clinic_services", $insert);

        return true;
    }

    /* ================================
       UPDATE SERVICE
    ================================= */
    public function updateService($id) {

        $update = [
            "category_id" => $_POST['category_id'],
            "service_name"=> $_POST['service_name'],
            "price"       => $_POST['price'],
            "description" => $_POST['description'],
            "updated_date"=> date("Y-m-d H:i:s")
        ];

        $this->db->update("tbl_clinic_services", $update, ["id" => $id]);

        return true;
    }

    /* ================================
       DELETE SERVICE (SOFT DELETE)
    ================================= */
    public function deleteService($id) {

        $this->db->update("tbl_clinic_services", [
            "status" => 'd'
        ], ["id" => $id]);

        return true;
    }

    /* ================================
       PAGE OUTPUT
    ================================= */
    public function getPageContent() {

        if(isset($_POST['action']) && $_POST['action'] == 'add'){
            $this->addService();
        }

        if(isset($_POST['action']) && $_POST['action'] == 'update'){
            $this->updateService($_POST['id']);
        }

        if(isset($_GET['delete'])){
            $this->deleteService($_GET['delete']);
        }

        $services = $this->getServicesList();

        echo "<h2>My Services</h2>";
        echo "<a href='?add=1'>Add Service</a><br><br>";

        foreach($services as $s){
            echo "<b>".$s['service_name']."</b> - ₹".$s['price']." (".$s['category_name'].") 
            <a href='?edit=".$s['id']."'>Edit</a> 
            <a href='?delete=".$s['id']."'>Delete</a><br>";
        }

        if(isset($_GET['add']) || isset($_GET['edit'])){
            $this->renderForm();
        }
	
    }


    /* ================================
       FORM
    ================================= */
    public function renderForm(){

        echo "
        <form method='post'>
            <input type='hidden' name='action' value='add'>
            Service Name:<br>
            <input type='text' name='service_name'><br>
            Price:<br>
            <input type='number' step='0.01' name='price'><br>
            Category ID:<br>
            <input type='number' name='category_id'><br>
            Description:<br>
            <textarea name='description'></textarea><br><br>
            <button type='submit'>Save</button>
        </form>
        ";
    }
}
